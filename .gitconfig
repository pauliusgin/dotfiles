[user]
	name = Paulius Giniūnas
    email = paulius.giniunas@gmail.com

[init]
    defaultBranch = main

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
    clean = git-ls clean -- %f

[core]
    editor = code --wait

[pull]
    rebase = false

[commit]
    template = ~/.gitconfig_commit_template

[alias]
	lg = !"echo '' && echo 'Newer commits at the top ⬆️, older commits at the bottom ⬇️' && echo '' && git log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s%n%b %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
    hlp = "!f() { \
        echo ''; \
        echo '📌 Git Cheat Sheet' 📌; \
        echo ''; \
        echo '• Branches:'; \
        echo '  git fetch --all --prune'; \
        echo '  git branch -r'; \
        echo '  git branch -u origin/<branch>'; \
        echo ''; \
        echo '• Unstage:'; \
        echo '  git reset (unstages all files)'; \
        echo '  git restore --staged'; \
        echo ''; \
        echo '• Undo commit:'; \
        echo '  git reset --soft HEAD~1 (keeps files staged)'; \
        echo '  git reset HEAD~1 (unstages files)'; \
        echo ''; \
        echo '• Amend commit:'; \
        echo '  git commit --amend'; \
        echo ''; \
        echo '• Interactive rebase:'; \
        echo '  git rebase -i HEAD~N (N = number of commits to show) '; \
        echo '   Example: '; \
        echo '   pick abc123 Commit 1 (only this commit will be left)'; \
        echo '   squash abc123 Commit 2 '; \
        echo '   squash abc123 Commit 3 '; \
        echo ''; \
        echo '• Stash:'; \
        echo '  git stash -m <message>'; \
        echo '  git stash -u (stash untracked files too)'; \
        echo '  git stash list'; \
        echo '  git stash pop <@{0}>'; \
        echo ''; \
        echo '• Remotes:'; \
        echo '  git remote -v (list remotes)'; \
        echo '  git remote remove <name>'; \
        echo '  git remote add <name> <url>'; \
        echo '  git remote prune origin'; \
        echo ''; \
    }; f"
