{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Remap ctrl+u and ctrl+d as Page Up and Page Down in browsers",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.google\\.Chrome$",
                                            "^org\\.mozilla\\.firefox$"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "d",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "page_down" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.google\\.Chrome$",
                                            "^org\\.mozilla\\.firefox$"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "u",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "page_up" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Use Tab/Shift+Tab to navigate Maccy",
                        "enabled": false,
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "org.p0deje.Maccy"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "tab",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "down_arrow" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "org.p0deje.Maccy"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "tab",
                                    "modifiers": { "mandatory": ["shift"] }
                                },
                                "to": [{ "key_code": "up_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Right Command → Hyper Key (⌃⌥⇧⌘) (Right Command if alone)",
                        "manipulators": [
                            {
                                "from": { "key_code": "right_command" },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "right_command" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Caps→Esc/Ctrl if held",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_control" }],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}